<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:HASS.Agent.UI"
        x:Class="HASS.Agent.UI.MainWindow"
        Title="HASS.Agent UI" Width="600" Height="400">
  <Design.DataContext>
    <vm:MainWindowViewModel/>
  </Design.DataContext>

  <StackPanel Margin="10">
    <StackPanel Orientation="Horizontal" Spacing="8">
      <Button Content="Service Status" Command="{Binding ServiceStatusCmd}" />
      <Button Content="Start Service" Command="{Binding ServiceStartCmd}" />
      <Button Content="Stop Service" Command="{Binding ServiceStopCmd}" />
      <TextBlock Text="{Binding ServiceStatusText}" Margin="8,0,0,0"/>
    </StackPanel>
    <TextBlock Text="Commands" FontWeight="Bold" FontSize="16"/>
    <ListBox Items="{Binding Commands}" SelectedItem="{Binding SelectedCommand}" Height="260">
      <ListBox.ItemTemplate>
        <DataTemplate>
          <StackPanel Orientation="Horizontal" Spacing="8">
            <TextBlock Text="{Binding Name}" Width="300"/>
            <TextBlock Text="{Binding State}" Width="80"/>
            <Button Content="Execute" Command="{Binding DataContext.ExecuteCommandCmd, RelativeSource={RelativeSource AncestorType=Window}}" CommandParameter="{Binding Id}"/>
          </StackPanel>
        </DataTemplate>
      </ListBox.ItemTemplate>
    </ListBox>
  </StackPanel>
</Window>
